# Duke's Gambit — server environment template
# Copy this file to .env and fill in the values before starting the server.
# All variables are optional; defaults are shown in the comments.

# ── Network ───────────────────────────────────────────────────────────────
# Interface address to bind. Use 0.0.0.0 to listen on all interfaces.
DUKE_HOST=0.0.0.0

# TCP port for the WebSocket listener.
DUKE_PORT=8765

# ── TLS ───────────────────────────────────────────────────────────────────
# Set to "1" to enable WSS with a self-signed certificate (default).
# Set to "0" to use plain WS — only safe on a trusted LAN or behind a TLS proxy.
DUKE_TLS=1

# Directory where server.crt / server.key / fingerprint are stored.
# Created automatically on first start if TLS is enabled.
DUKE_CERT_DIR=./certs

# ── Session tokens ────────────────────────────────────────────────────────
# HMAC secret used to sign session tokens.
# If left empty, a random secret is generated on each start
# (clients will lose their sessions after a server restart).
# Recommended: at least 32 random characters.
DUKE_SESSION_SECRET=

# ── Limits ────────────────────────────────────────────────────────────────
# Maximum number of concurrent rooms.
DUKE_MAX_ROOMS=256

# Maximum number of simultaneous WebSocket connections.
DUKE_MAX_CLIENTS=1000

# Auto-close empty rooms that have been idle for this many seconds.
DUKE_ROOM_IDLE_S=600

# ── Game timings ──────────────────────────────────────────────────────────
# How many seconds a disconnected in-game player has to reconnect
# before they forfeit the game.
DUKE_RECONNECT_S=30

# Reject moves whose client-side timestamp is older than this many seconds.
DUKE_MOVE_MAX_AGE_S=30

# WebSocket ping interval in seconds (timeout is 2× this value).
DUKE_HEARTBEAT_S=20

# ── Logging ───────────────────────────────────────────────────────────────
# Python logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
DUKE_LOG_LEVEL=INFO
