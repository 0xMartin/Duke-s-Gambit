[gd_scene load_steps=12 format=3 uid="uid://game"]

[ext_resource type="Script"      path="res://scripts/game_controller.gd"  id="1"]
[ext_resource type="PackedScene" path="res://scenes/board.tscn"            id="2"]
[ext_resource type="PackedScene" path="res://scenes/orbit_camera.tscn"     id="3"]
[ext_resource type="Script"      path="res://scripts/ui/game_ui.gd"        id="4"]
[ext_resource type="Script"      path="res://scripts/ui/hud.gd"            id="5"]
[ext_resource type="Texture2D"   path="res://assets/textures/skybox.png"   id="6"]

[sub_resource type="PanoramaSkyMaterial" id="SkyMat1"]
panorama = ExtResource("6")

[sub_resource type="Sky" id="Sky1"]
sky_material = SubResource("SkyMat1")

[sub_resource type="Environment" id="Env1"]
background_mode = 2
sky = SubResource("Sky1")
ambient_light_source = 2
ambient_light_color = Color(0.95, 0.92, 0.88, 1)
ambient_light_energy = 0.8

[node name="GameScene" type="Node3D"]
script = ExtResource("1")
board_node  = NodePath("Board")
camera_node = NodePath("OrbitCamera")
pieces_root = NodePath("Pieces")
ui_root     = NodePath("UI")

[node name="Board" parent="." instance=ExtResource("2")]

[node name="OrbitCamera" parent="." instance=ExtResource("3")]

[node name="Pieces" type="Node3D" parent="."]

[node name="WorldEnvironment" type="WorldEnvironment" parent="."]
environment = SubResource("Env1")

[node name="DirectionalLight3D" type="DirectionalLight3D" parent="."]
transform = Transform3D(0.707, -0.5, 0.5, 0, 0.707, 0.707, -0.707, -0.5, 0.5, 0, 8, 0)
light_energy = 1.2
shadow_enabled = true

[node name="UI" type="Control" parent="."]
layout_mode = 3
anchors_preset = 15
mouse_filter = 2
script = ExtResource("4")

[node name="HUD" type="Control" parent="UI"]
mouse_filter = 2
script = ExtResource("5")

[node name="AIThinkingLabel" type="Label" parent="UI"]
layout_mode = 1
anchors_preset = 5
anchor_left = 0.5
anchor_right = 0.5
grow_horizontal = 2
offset_top = 16.0
offset_bottom = 48.0
text = "AI is thinking..."
horizontal_alignment = 1
visible = false

[node name="GameOverPanel" type="PanelContainer" parent="UI"]
layout_mode = 1
anchor_left = 0.25
anchor_top = 0.25
anchor_right = 0.75
anchor_bottom = 0.75
grow_horizontal = 2
grow_vertical = 2
visible = false

[node name="VBox" type="VBoxContainer" parent="UI/GameOverPanel"]
layout_mode = 2

[node name="Label" type="Label" parent="UI/GameOverPanel/VBox"]
layout_mode = 2
size_flags_vertical = 3
text = "Game Over"
horizontal_alignment = 1
vertical_alignment = 1
autowrap_mode = 3
theme_override_font_sizes/font_size = 52

[node name="BackButton" type="Button" parent="UI/GameOverPanel/VBox"]
layout_mode = 2
custom_minimum_size = Vector2(0, 64)
size_flags_horizontal = 4
theme_override_font_sizes/font_size = 36
text = "Back to Menu"

[node name="PromotionPanel" type="PanelContainer" parent="UI"]
